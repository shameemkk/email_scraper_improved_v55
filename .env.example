# --- 32 GB RAM / 16 vCPU CONFIG ---
NUM_WORKERS=10
PLAYWRIGHT_MAX_CONTEXTS=6
SUBPAGE_CONCURRENCY=8
MAX_SUBPAGE_CRAWLS=30
MAX_LINKS_PER_PAGE=50

# Memory breakdown:
#   10 workers × 2 GB Node.js heap           = ~20 GB
#   10 workers × 6 contexts × ~120 MB Chromium = ~7.2 GB
#   OS + Docker + buffer                      = ~4.8 GB
#   Total ≈ 32 GB
#
# Max parallelism: 10 × 6 × 8 = 480 concurrent page operations

# Navigation timeout — 30s keeps throughput high
PAGE_NAVIGATION_TIMEOUT_MS=60000

# Overall request timeout (ms) — max time for a single /extract-emails request (default: 120000)
OVERALL_TIMEOUT_MS=120000

# Optional: rate limiting if hitting blocks
# SCRAPE_DELAY_MIN_MS=100
# SCRAPE_DELAY_MAX_MS=500

# Optional: crawl depth (default: 2)
# MAX_DEPTH=2

# Optional: proxy rotation
# PROXY_URLS=http://proxy1:port,http://proxy2:port
