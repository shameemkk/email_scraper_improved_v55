# --- 25 GB RAM CONFIG (recommended) ---
NUM_WORKERS=8
PLAYWRIGHT_MAX_CONTEXTS=8
SUBPAGE_CONCURRENCY=6
MAX_SUBPAGE_CRAWLS=30
MAX_LINKS_PER_PAGE=50

# Memory breakdown:
#   8 workers × 2 GB Node.js heap  = ~16 GB
#   8 workers × 8 contexts × ~150 MB Chromium = ~9.6 GB
#   Total ≈ 25 GB

# Optional: rate limiting if hitting blocks
# SCRAPE_DELAY_MIN_MS=100
# SCRAPE_DELAY_MAX_MS=500

# Optional: crawl depth
# MAX_DEPTH=2

# Optional: navigation timeout per page (ms) — increase for slow sites or high concurrency
#PAGE_NAVIGATION_TIMEOUT_MS=30000
